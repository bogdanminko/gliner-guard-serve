FROM python:3.12-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app
COPY test-script/pyproject.toml test-script/uv.lock ./
RUN uv sync --frozen --no-dev

COPY test-script/ ./data/

EXPOSE 8089
ENTRYPOINT ["uv", "run", "locust", "-f", "/app/data/test-gliner.py", "--headless"]
CMD ["--csv=/app/results/benchmark"]
