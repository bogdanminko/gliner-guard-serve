# Reproducible config for Ray Serve REST on one A100 with four worker replicas.
# This mirrors the LitServe baseline shape: workers_per_device=4,
# max_batch_size in {16,32,64}, batch_timeout=0.05s, 100 Locust users.
#
# For four physical A100 GPUs instead of one A100 shared by four workers:
#   GPU_COUNT=4
#   NUM_GPUS_PER_REPLICA=1

# Model
HF_TOKEN=
MODEL_ID=hivetrace/gliner-guard-uniencoder
SCHEMA_MODE=minimal

# Docker GPU exposure
GPU_COUNT=1

# Ray Serve worker topology
NUM_REPLICAS=4
NUM_GPUS_PER_REPLICA=0.25
NUM_CPUS_PER_REPLICA=3
MAX_ONGOING_REQUESTS=256

# Ray Serve batching
TORCH_DTYPE=bf16
MAX_BATCH_SIZE=64
BATCH_WAIT_TIMEOUT=0.05
MAX_CONCURRENT_BATCHES=1
RAY_SERVE_THROUGHPUT_OPTIMIZED=0

# Locust load profile
LOCUST_USERS=100
LOCUST_SPAWN_RATE=1
LOCUST_RUN_TIME=15m
LOCUST_USER_THROUGHPUT=5
DATASET=prompts

# Benchmark sweep defaults
REPEATS=3
BATCH_CONFIGS=16:0.05,32:0.05,64:0.05
WARMUP_REQS=50

# Registry
REGISTRY=harbor.adapstory.com/adapstory
TAG=dev
